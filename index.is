@ Role: contact-page — form with validation and submission feedback
page Contact() {
    state name = ""
    state email = ""
    state message = ""
    state submitting = false
    state submitted = false

    column {
        scrollable: true
        align: (center, top)

        row {
            Link("← Back to home") {
                on click { back() }
            }
        }

        @ Role: contact-intro
        Section("Get in touch") {
            Text("I'm open to freelance contracts, internships, and full-time opportunities — remote or hybrid.")
            Text("Prefer email directly? dev.davi.macedo.gomes@gmail.com")
        }

        Divider()

        @ Role: contact-form
        Section("Send a message") {
            if submitted {
                @ Role: success-state — confirmation after form submission
                Alert("Thanks for reaching out! I'll get back to you as soon as possible.") {
                    variant: success
                }
                Button("Send another message") {
                    on click {
                        submitted = false
                        name = ""
                        email = ""
                        message = ""
                    }
                }
            } else {
                Form {
                    on submit { validate() }

                    Input("Your name") {
                        required: true
                        placeholder: "Name"
                        error: name == "" && submitting ? "Name is required" : false
                        on input { name = value }
                    }

                    Input("Your email") {
                        required: true
                        placeholder: "you@example.com"
                        error: email == "" && submitting ? "Email is required" : false
                        on input { email = value }
                    }

                    Input("Message") {
                        required: true
                        placeholder: "Tell me about your project or opportunity..."
                        error: message == "" && submitting ? "Message is required" : false
                        on input { message = value }
                    }

                    @ Role: primary-action
                    Button("Send message") {
                        loading: submitting
                        on click {
                            if name != "" && email != "" && message != "" {
                                submitting = true
                                delay(1500, Toast("Message sent! I'll get back to you soon."))
                                delay(1500, submitted = true)
                                delay(1500, submitting = false)
                            } else {
                                submitting = true
                                delay(100, submitting = false)
                            }
                        }
                    }
                }
            }
        }

        Divider()

        @ Role: alternative-contact
        Section("Or find me on") {
            row {
                @ A11y: external-link
                Link("GitHub")
                @ A11y: external-link
                Link("LinkedIn")
            }
        }
    }
}
