@* Viewport-safe single-page portfolio for Davi Macêdo Gomes.
   Root column fills viewport height and scrolls internally.
   Content centered with max-width constraint on desktop.
   Sections separated by dividers for scannability.
   Contact modal at page level (outside scrollable). *@
page Main() {
    state contactOpen = false

    column {
        scrollable: true
        align: (center, top)

        @ Identity header — compact, no hero imagery
        Section("Davi Macêdo Gomes") {
            row {
                collapse: true
                Badge("Full-Stack Developer + AI Engineer") {
                    variant: info
                }
                Text("📍 Remote / Feira de Santana, BA, Brasil")
            }

            @ responsive: collapse to stacked links on mobile
            row {
                collapse: true
                Link("📧 Email") {
                    on click { Toast("Open email client") }
                }
                Link("🐙 GitHub") {
                    on click { Toast("Open GitHub profile") }
                }
                Link("🔗 LinkedIn") {
                    on click { Toast("Open LinkedIn profile") }
                }
            }
        }

        Divider()

        Section("About Me") {
            Text("Full-stack developer and AI engineer passionate about building practical tools that bridge the gap between complex systems and real-world usability. Currently pursuing Computer Engineering at UEFS while freelancing — delivering web applications and AI-powered automation. I thrive at the intersection of backend engineering, CLI tooling, and LLM-based agent systems, always looking to simplify developer experience and automate the tedious.")
        }

        Divider()

        Section("Tech Stack") {
            @ responsive: collapse table rows to stacked label-value cards on mobile
            Table(["Category", "Technologies"], [
                ["Languages", "Python, Go, JavaScript / TypeScript, HTML, CSS, Shell"],
                ["Frontend", "React, HTMX, Vite, Tailwind CSS, vanilla JS"],
                ["Backend", "FastAPI, Gin, Go std lib, Django"],
                ["Databases", "PostgreSQL, MySQL, SQLite"],
                ["AI / LLM", "LangChain, OpenAI API, tool-calling agents, LLM orchestration"],
                ["DevOps", "Docker, Git, CI/CD (GitHub Actions), Linux, Bash"],
                ["Testing", "Gherkin (BDD), MSW (API mocking), Go tests"],
                ["Editor", "Neovim, VS Code · Agent: pi"]
            ])
        }

        Divider()

        @ Projects — varied structure: featured card, standard cards, compact rows for experiments
        Section("Projects") {
            @ role: featured-card
            Card("RouteHub — Bus Transportation Platform") {
                Text("Full-Stack · React · FastAPI · PostgreSQL · Docker · JWT · Spec-Driven")
                Text("Digital platform for managing, scheduling, and monitoring institutional bus transportation. Serves students, staff, drivers, and administrators with auth, trip booking, check-in, PDF reports, and notifications. Built spec-first with specs/ defining every story and edge case.")
                row {
                    collapse: true
                    Badge("React") { variant: info }
                    Badge("FastAPI") { variant: info }
                    Badge("PostgreSQL") { variant: info }
                    Badge("Docker") { variant: info }
                    Badge("JWT") { variant: info }
                    Badge("Spec-Driven") { variant: success }
                }
                Link("View on GitHub →") {
                    on click { Toast("Open RouteHub repo") }
                }
            }

            Card("my-agent — LLM Agent Framework") {
                Text("Go · LLM · Tool-Calling · Streaming · Mock Implementation")
                Text("Go-based LLM agent framework with a provider-agnostic interface, tool-calling agent loop, and MockLLM for testing without API keys. Supports streaming via iterator pattern, with CI pipeline via GitHub Actions.")
                row {
                    collapse: true
                    Badge("Go") { variant: info }
                    Badge("Tool-Calling") { variant: info }
                    Badge("Streaming") { variant: info }
                }
                Link("View on GitHub →") {
                    on click { Toast("Open my-agent repo") }
                }
            }

            Card("unipm — Universal Package Manager") {
                Text("Go · CLI · Cross-Platform · Distrobox")
                Text("Meta package manager unifying apt, npm, pip, flatpak, brew, pacman, and Distrobox under one CLI. Interactive source selection when packages exist in multiple ecosystems. Gherkin-based BDD test suite.")
                row {
                    collapse: true
                    Badge("Go") { variant: info }
                    Badge("CLI") { variant: info }
                }
                Link("View on GitHub →") {
                    on click { Toast("Open unipm repo") }
                }
            }

            Card("denteclean — Dental Clinic Landing Page") {
                Text("HTML5 · CSS3 · Vanilla JS · Responsive · No Frameworks")
                Text("Static single-page site for a fictional premium dental clinic. Zero frameworks, zero build steps — pure HTML/CSS/JS with full responsive design across desktop, tablet, and mobile. Deployed via GitHub Pages.")
                row {
                    collapse: true
                    Badge("HTML5") { variant: info }
                    Badge("CSS3") { variant: info }
                    Badge("Vanilla JS") { variant: info }
                    Badge("Responsive") { variant: success }
                }
                row {
                    Link("🔗 Live Demo →") {
                        on click { Toast("Open live demo") }
                    }
                    Link("View on GitHub →") {
                        on click { Toast("Open denteclean repo") }
                    }
                }
            }

            @ role: compact-summary
            Section("Early Experiments") {
                Text("• TUI Dental Clinic System — Terminal-based management interface (exploratory)")
                Text("• Manga Translator (PT-BR) — OpenCV-based English-to-Portuguese manga translation pipeline")
            }
        }

        Divider()

        Section("Experience") {
            Card("Freelance Developer") {
                Text("Less than 1 year")
                Text("Full-stack applications, CLI tools, and LLM-powered workflows for diverse clients.")
            }
        }

        Divider()

        Section("Education") {
            Text("B.Sc. Computer Engineering (2023 – 2029) — UEFS, Bahia, Brasil")
            row {
                collapse: true
                Badge("IoT Certificate") { variant: info }
                Badge("Programming Marathon Participant") { variant: info }
            }
        }

        Divider()

        Section("Languages & Strengths") {
            Text("Languages:")
            row {
                collapse: true
                Badge("Portuguese — Native") { variant: info }
                Badge("English — Advanced R&L / Conversational") { variant: info }
            }
            Text("Strengths:")
            Text("• Self-directed learner — picks up tools quickly by building real projects")
            Text("• Problem finder & solver — spots edge cases and failure modes others overlook")
            Text("• Detail-oriented — correctness, error handling, UX polish")
            Text("• Tool builder — creating developer tools and automation that simplify workflows")
        }

        Divider()

        Section("Beyond Code") {
            Text("• 🐧 Linux enthusiast — Debian daily driver, Arch at heart, eyeing Void Linux")
            Text("• 🔧 Harness engineering — deep into AI/automation as a hobby and craft")
            Text("• 🎮 MOBA player — when the terminal needs a break")
        }

        Divider()

        @ Call to action
        Section("Currently") {
            Text("Open to freelance contracts, internships, and full-time opportunities — remote or hybrid. Most interested in AI/automation, developer tooling, and backend infrastructure.")
            Text("\"The best way to predict the future is to build it.\"")

            @ role: primary-action
            Button("Get in touch →") {
                on click { toggle(contactOpen) }
            }
        }
    }

    @ Page-level contact modal — outside scrollable column
    if contactOpen {
        Modal("Get in Touch") {
            on close { contactOpen = false }

            Link("📧 dev.davi.macedo.gomes@gmail.com") {
                on click { Toast("Open email client") }
            }
            Link("🐙 github.com/DaviMGDev") {
                on click { Toast("Open GitHub") }
            }
            Link("🔗 linkedin.com/in/dav1-maced0-g0mes-dev") {
                on click { Toast("Open LinkedIn") }
            }

            Button("Close") {
                on click { contactOpen = false }
            }
        }
    }
}
